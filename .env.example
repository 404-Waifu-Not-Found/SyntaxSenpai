# SyntaxSenpai AI configuration
# Copy this file to .env and fill only the providers you plan to use.

# Global defaults
SYNTAX_SENPAI_AI_PROVIDER=anthropic
SYNTAX_SENPAI_AI_MODEL=

# Optional provider-specific model override keys
# SYNTAX_SENPAI_MODEL_ANTHROPIC=claude-sonnet-4-20250514
# SYNTAX_SENPAI_MODEL_OPENAI=gpt-4o
# SYNTAX_SENPAI_MODEL_OLLAMA=llama2

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Groq
GROQ_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=

# Replicate
REPLICATE_API_KEY=

# Hugging Face
HUGGINGFACE_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# xAI Grok
XAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE_NAME=

# AWS Bedrock
AWS_BEDROCK_API_KEY=

# Fireworks
FIREWORKS_API_KEY=
