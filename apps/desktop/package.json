{
  "name": "syntax-senpai-desktop",
  "version": "0.0.1",
  "description": "SyntaxSenpai desktop app (Electron)",
  "author": "unoxyrich",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoxyrich/SyntaxSenpai.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron dist/main/index.js",
    "build": "electron-vite build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@syntax-senpai/agent-tools": "workspace:*",
    "@syntax-senpai/ai-core": "workspace:*",
    "@syntax-senpai/logger": "workspace:*",
    "@syntax-senpai/storage": "workspace:*",
    "@syntax-senpai/ui": "workspace:*",
    "@syntax-senpai/ui-loading-screens": "workspace:*",
    "@syntax-senpai/ui-transitions": "workspace:*",
    "@syntax-senpai/waifu-core": "workspace:*",
    "@syntax-senpai/ws-protocol": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "electron-squirrel-startup": "^1.0.1",
    "keytar": "^7.9.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "ws": "^8.17.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@types/qrcode": "^1.5.5",
    "@unocss/reset": "^66.6.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^31.0.0",
    "electron-builder": "^24.6.4",
    "electron-vite": "^2.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.2",
    "unocss": "^66.6.7",
    "vite": "^6.0.0",
    "vue-tsc": "^3.2.6",
    "electron-rebuild": "^3.2.0"
  },
    "build": {
    "productName": "SyntaxSenpai",
    "appId": "ai.syntaxsenpai",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "dist/preload/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "asar": false,
    "publish": []
  }
}
