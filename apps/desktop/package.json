{
  "name": "syntax-senpai-desktop",
  "version": "0.0.1",
  "description": "SyntaxSenpai desktop app (Electron)",
  "author": "unoxyrich",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoxyrich/SyntaxSenpai.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron dist/main/index.js",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@syntax-senpai/agent-tools": "workspace:*",
    "@syntax-senpai/ai-core": "workspace:*",
    "@syntax-senpai/storage": "workspace:*",
    "@syntax-senpai/ui": "workspace:*",
    "@syntax-senpai/waifu-core": "workspace:*",
    "@syntax-senpai/ws-protocol": "workspace:*",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "keytar": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.17.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.6.4",
    "electron-vite": "^2.0.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "electron-rebuild": "^3.2.0"
  },
  "build": {
    "productName": "SyntaxSenpai",
    "appId": "ai.syntaxsenpai",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "dist/preload/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg","zip"],
      "category": "public.app-category.developer-tools"
    },
    "asar": false,
    "publish": []
  }
}
