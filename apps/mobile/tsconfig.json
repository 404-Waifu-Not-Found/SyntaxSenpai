{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@syntax-senpai/ai-core": ["../../packages/ai-core/src"],
      "@syntax-senpai/ai-core/*": ["../../packages/ai-core/src/*"],
      "@syntax-senpai/agent-tools": ["../../packages/agent-tools/src"],
      "@syntax-senpai/agent-tools/*": ["../../packages/agent-tools/src/*"],
      "@syntax-senpai/waifu-core": ["../../packages/waifu-core/src"],
      "@syntax-senpai/waifu-core/*": ["../../packages/waifu-core/src/*"],
      "@syntax-senpai/ui": ["../../packages/ui/src"],
      "@syntax-senpai/ui/*": ["../../packages/ui/src/*"],
      "@syntax-senpai/ws-protocol": ["../../packages/ws-protocol/src"],
      "@syntax-senpai/ws-protocol/*": ["../../packages/ws-protocol/src/*"],
      "@syntax-senpai/storage": ["../../packages/storage/src"],
      "@syntax-senpai/storage/*": ["../../packages/storage/src/*"]
    }
  },
  "include": ["app", "src"],
  "exclude": ["node_modules", "dist"]
}
