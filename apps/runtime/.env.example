# SyntaxSenpai Runtime — copy this file to .env and fill in values.

# Network
HOST=0.0.0.0
PORT=8787

# Auth — set a non-empty value to require "Authorization: Bearer <token>"
# on all /api/v1/ routes (backup export/restore, plugin list, telemetry).
# Leave empty to disable auth (default, safe for local-only use).
RUNTIME_AUTH_TOKEN=

# Storage directories
SYNTAX_SENPAI_DATA_DIR=./data
SYNTAX_SENPAI_PLUGIN_DIR=./plugins
SYNTAX_SENPAI_BACKUP_DIR=./data/backups

# Backup retention
BACKUP_MAX_FILES=20
BACKUP_RETENTION_DAYS=14

# Service metadata (shown in /healthz responses)
SERVICE_NAME=syntax-senpai-runtime
APP_VERSION=0.0.1
