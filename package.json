{
  "name": "syntax-senpai",
  "version": "0.0.1",
  "packageManager": "pnpm@8.13.0",
  "description": "AI-powered waifu companion for developers",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "desktop:quick": "pnpm --filter syntax-senpai-desktop run dev:quick",
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:desktop": "turbo run dev --filter=desktop",
    "dev:runtime": "pnpm --filter syntax-senpai-runtime run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "pnpm -w -r --if-present run test:unit",
    "lint": "turbo run lint",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "docker:build": "docker build -f Dockerfile -t syntax-senpai-runtime:local .",
    "docker:up": "docker compose up --build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "20.3.1",
    "prebuild-install": "^7.1.3",
    "tsdown": "0.21.7",
    "turbo": "^2.9.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.0.0"
  }
}
