{
  "name": "@proj-airi/electron-vueuse",
  "type": "module",
  "version": "0.9.0-beta.6",
  "private": true,
  "description": "VueUse-like composables and helpers for Electron apps",
  "author": {
    "name": "Moeru AI Project AIRI Team",
    "email": "airi@moeru.ai",
    "url": "https://github.com/moeru-ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moeru-ai/airi.git",
    "directory": "packages/electron-vueuse"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./main": {
      "import": "./dist/main/index.mjs",
      "default": "./dist/main/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "pnpm run build",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "electron": ">=39 <41",
    "vue": ">=3"
  },
  "dependencies": {
    "@moeru/eventa": "^1.0.0-beta.3",
    "@moeru/std": "^0.1.0-beta.17",
    "@vueuse/core": "^14.2.1",
    "es-toolkit": "^1.45.1",
    "std-env": "^4.0.0"
  },
  "devDependencies": {
    "@proj-airi/electron-eventa": "workspace:*"
  }
}
