{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@syntax-senpai/ai-core": ["packages/ai-core/src"],
      "@syntax-senpai/ai-core/*": ["packages/ai-core/src/*"],
      "@syntax-senpai/agent-tools": ["packages/agent-tools/src"],
      "@syntax-senpai/agent-tools/*": ["packages/agent-tools/src/*"],
      "@syntax-senpai/waifu-core": ["packages/waifu-core/src"],
      "@syntax-senpai/waifu-core/*": ["packages/waifu-core/src/*"],
      "@syntax-senpai/ui": ["packages/ui/src"],
      "@syntax-senpai/ui/*": ["packages/ui/src/*"],
      "@syntax-senpai/ws-protocol": ["packages/ws-protocol/src"],
      "@syntax-senpai/ws-protocol/*": ["packages/ws-protocol/src/*"],
      "@syntax-senpai/storage": ["packages/storage/src"],
      "@syntax-senpai/storage/*": ["packages/storage/src/*"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist", ".expo"]
}
